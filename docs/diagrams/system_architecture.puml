@startuml System Architecture

title SOME/IP Stack System Architecture

package "Application Layer" as App {
    component [SOME/IP Client] as Client
    component [SOME/IP Server] as Server
    component [Service Proxy] as Proxy
    component [Service Skeleton] as Skeleton
}

package "Protocol Layer" as Protocol {
    component [RPC Engine] as RPC
    component [Event System] as Events
    component [Service Discovery] as SD
    component [Transport Protocol] as TP
}

package "Transport Layer" as Transport {
    component [UDP Transport] as UDP
    component [TCP Transport] as TCP
    component [Multicast Manager] as MCast
    component [Connection Manager] as ConnMgr
}

package "Core Layer" as Core {
    component [Message Serializer] as Serializer
    component [Message Parser] as Parser
    component [Session Manager] as SessionMgr
    component [Error Handler] as ErrorHandler
}

package "Safety Layer" as Safety {
    component [Fault Monitor] as FaultMon
    component [Safety Manager] as SafetyMgr
    component [Recovery Manager] as RecoveryMgr
    component [Diagnostic Interface] as Diag
}

package "Platform Abstraction Layer" as PAL {
    component [thread.h] as ThreadH
    component [memory.h] as MemoryH
    component [net.h] as NetH
    component [byteorder.h] as ByteorderH

    note right of PAL
        Public headers contain only
        common code + #include "*_impl.h".
        CMake selects the backend via
        include-path (-I) at build time.
    end note
}

package "Platform Backends" as Backends {
    package "POSIX" as POSIX_BE {
        component [std::thread\nstd::mutex] as POSIX_Thread
        component [POSIX sockets] as POSIX_Net
        component [std::make_shared] as POSIX_Mem
    }
    package "Zephyr" as Zephyr_BE {
        component [k_thread\nk_mutex\nk_condvar] as Zephyr_Thread
        component [zsock_ API] as Zephyr_Net
        component [k_mem_slab] as Zephyr_Mem
    }
    package "FreeRTOS + lwIP" as FreeRTOS_BE {
        component [xTaskCreate\nxSemaphore] as FreeRTOS_Thread
        component [lwip sockets] as FreeRTOS_Net
        component [Static pool] as FreeRTOS_Mem
    }
    package "ThreadX + lwIP" as ThreadX_BE {
        component [tx_thread\nTX_MUTEX] as ThreadX_Thread
        component [lwip sockets] as ThreadX_Net
        component [TX_BLOCK_POOL] as ThreadX_Mem
    }
}

' Application to Protocol
Client --> RPC : RPC Calls
Server --> RPC : RPC Responses
Proxy --> SD : Service Discovery
Skeleton --> Events : Event Publishing

' Protocol to Transport
RPC --> UDP : UDP Messages
RPC --> TCP : TCP Messages
SD --> MCast : Multicast Messages
TP --> UDP : Segmented Messages

' Protocol to Core
RPC --> Serializer : Serialize Messages
RPC --> Parser : Parse Messages
SD --> SessionMgr : Session Management
Events --> SessionMgr : Event Sessions

' All layers to Safety
App --> SafetyMgr : Safety Monitoring
Protocol --> FaultMon : Fault Detection
Transport --> FaultMon : Transport Faults
Core --> RecoveryMgr : Error Recovery

' Transport and Core to PAL
Transport --> ThreadH : platform::Thread\nplatform::Mutex
Transport --> NetH : Sockets
Transport --> MemoryH : allocate_message()
Core --> ThreadH : platform::Mutex
Core --> ByteorderH : someip_htons()

' PAL to Backends (one backend active at build time)
ThreadH ..> POSIX_Thread
ThreadH ..> Zephyr_Thread
ThreadH ..> FreeRTOS_Thread
ThreadH ..> ThreadX_Thread
NetH ..> POSIX_Net
NetH ..> Zephyr_Net
NetH ..> FreeRTOS_Net
NetH ..> ThreadX_Net
MemoryH ..> POSIX_Mem
MemoryH ..> Zephyr_Mem
MemoryH ..> FreeRTOS_Mem
MemoryH ..> ThreadX_Mem

' Safety to Infrastructure
SafetyMgr --> ThreadH : Thread Safety

note right of Transport
    Transport uses only
    platform:: types -- never
    std::thread or raw sockets.
end note

note right of Backends
    Only one backend is active
    per build. Selection is via
    CMake include-path, not #ifdef.
end note

@enduml
